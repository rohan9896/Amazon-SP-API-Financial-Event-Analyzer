PORT=3000
NODE_ENV=development

# Fake LWA credentials — no real Amazon account required
CLIENT_ID=amzn1.application-oa2-client.mockspapi
CLIENT_SECRET=mock_client_secret
MOCK_REFRESH_TOKEN=Atzr|mock_refresh_token
ACCESS_TOKEN_TTL_SECONDS=3600

# Usage:
# 1. POST /auth/o2/token with client_id + client_secret (grant_type=client_credentials)
# 2. Use access_token as x-amz-access-token on business routes (later)
# 3. POST /auth/o2/token with grant_type=refresh_token to get a new access_token
