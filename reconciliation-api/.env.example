# Product API server
PORT=4000
# Comma-separated allowed CORS origins for the SPA (use * to allow all in dev)
CORS_ORIGIN=http://localhost:5173

# Mock SP-API (reuses the same credentials as sp-api-service/.env)
SP_API_BASE_URL=http://localhost:3000
SP_API_CLIENT_ID=amzn1.application-oa2-client.mockspapi
SP_API_CLIENT_SECRET=mock_client_secret
# Or use CLIENT_ID / CLIENT_SECRET (same names as sp-api-service)

# Reconciliation config
COMMISSION_RATE=0.15
SHORTPAY_TOLERANCE=0.50
CREATED_AFTER=2020-01-01T00:00:00Z

# How long (ms) to cache the fetched+normalized+reconciled dataset
DATA_CACHE_TTL_MS=30000

# LLM explanation layer (only needed for POST /api/explain/:orderId).
# Keep this key separate from the SP-API credentials above.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
